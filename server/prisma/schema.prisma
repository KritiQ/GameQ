datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int             @id @default(autoincrement())
  username  String          @unique
  email     String          @unique
  password  String
  backlog   BacklogEntry[]
  createdAt DateTime        @default(now())
}

model Game {
  id              Int      @id @default(autoincrement())
  rawgId          Int      @unique
  title           String
  cover           String?
  released        String?
  rating          Float?

  description     String?
  backgroundExtra String?
  website         String?
  metacritic      Int?
  playtime        Int?

  platforms       String?
  genres          String?

  backlog         BacklogEntry[]
}

model BacklogEntry {
  id       Int      @id @default(autoincrement())
  user     User     @relation(fields: [userId], references: [id])
  userId   Int
  game     Game     @relation(fields: [gameId], references: [id])
  gameId   Int
  status   String
  addedAt  DateTime @default(now())
}
